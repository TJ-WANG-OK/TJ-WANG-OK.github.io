@inproceedings{2017-iwcmc,
  abbr        = {IWCMC},
  bibtex_show = {true},
  title       = {Block-Sparse Compressive Sensing Based Multi-User and Signal Detection for Generalized Spatial Modulation in NOMA},
  author      = {Wang, Tengjiao and Liu, Sicong and Yang, Fang and Wang, Jintao and Song, Jian and Han, Zhu},
  booktitle   = {2017 13th International Wireless Communications and Mobile Computing Conference (IWCMC)},
  pages       = {1992--1997},
  year        = {2017},
  organization={IEEE},
  doi         = {10.1109/IWCMC.2017.7986589},
  pdf         = {bib-2017-iwcmc.pdf},
  preview     = {2017-iwcmc.png},
  abstract    = {The non-orthogonal multiple access (NOMA) technology has been proposed and regarded as one of the potential promising technologies for the future 5G network. The extension of generalized spatial modulation multiple-input multiple-output (MIMO) to NOMA system improves both the spectral and energy efficiencies of the system, while maintaining the massive connectivity and low latency advantages, but it puts forward challenges for the multi-user and signal detection as well. In this paper, we propose a joint user activity and signal detection scheme based on the block-sparse compressive sensing (BS-CS) method in the uplink NOMA system, in which the generalized spatial modulation MIMO technology is used. By exploiting the structure and sparsity of the multi-user generalized spatial modulation signals, we formulate the detection problem into a block-sparse recovery problem. Then a BS-CS based detection algorithm, enhanced structured block-sparse compressive sampling matching pursuit (ESB-CoSaMP), is proposed to detect the active users and transmitted data efficiently. Moreover, the information of active antennas at each user is exploited in ESB-CoSaMP to further improve the accuracy. Simulations show that the proposed detection scheme outperforms the conventional CS and BS-CS based schemes.}
}

@inproceedings{2017-iwcmc-2,
  abbr        = {IWCMC},
  bibtex_show = {true},
  title       = {Constellation and Labeling Optimization for Bit-Interleaved Coded Spatial Modulation System},
  author      = {An, Zhecheng and Wang, Jun and Wang, Jintao and Wang, Tengjiao and Song, Jian},
  booktitle   = {2017 13th International Wireless Communications and Mobile Computing Conference (IWCMC)},
  pages       = {1998--2003},
  year        = {2017},
  organization={IEEE},
  doi         = {10.1109/IWCMC.2017.7986590},
  pdf         = {bib-2017-iwcmc-2.pdf},
  preview     = {2017-iwcmc-2.png},
  abstract    = {In spatial modulation (SM) systems, the distribution of amplitude-phase modulation (APM) symbol causes the tradeoff of detection performance between APM symbol and active antenna, which infers the overall capacity of SM system. In this paper, the APM constellation and symbol labeling of SM system is investigated. The optimized APM constellation is designed to maximize the system coded modulation average mutual information (CM-AMI). The symbol labeling of SM system is optimized with binary switching algorithm (BSA) using the symbol detection pairwise error probability (PEP) criteria. Moreover, the proposed APM constellation and symbol labeling are applied in a coded spatial modulation (SM) system with the bit-interleaved coded modulation and iterative demapping (BICM-ID). Simulation result shows the BICM-ID SM system with proposed constellation and symbol labeling has a signal-to-noise ratio (SNR) gain compared to conventional constellation system and independent demapping system.}
}
